.agent

# Certificates / keys
certs/

# Language-specific build caches
_build/
.zig-cache/
__pycache__/
*.pyc

# Compiled objects
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll

# Fuzz harness outputs (psizam wasm crash / mismatch reproducers).
# Reproducers worth checking in should be moved into a tracked
# corpus directory — drop-them-where-the-fuzzer-runs is artifact
# territory, not source.
libraries/psizam/tests/fuzz/*.wasm
libraries/psizam/tests/fuzz/wasm-gen/*.wasm
libraries/psizam/tests/fuzz/wasm-gen/reproducers/

# Stray fuzz outputs at any path. The fuzzer occasionally drops
# crashes at the working directory rather than the fuzz dir; catch
# both at top level and in any subtree.
crash_*.wasm
mismatch_*.wasm

# Per-run benchmark snapshots. Default-untracked; commit a snapshot
# only when intentionally pinning it as a baseline (`git add -f`).
bench_snapshots/

# Added by cargo

/target

# FetchContent_Declare populates this from gofractally/psio.
external/psio/
