// <condition_variable> shim for LLVM built against no-threads libc++.
//
// libc++'s real <condition_variable> emits a hard #error when threads are
// disabled, so we cannot include_next it in that mode. Instead we provide
// a compile-only stub sufficient for LLVM's unconditional references
// (struct fields, member function declarations). Call sites are guarded
// by LLVM_ENABLE_THREADS, so the stub methods are never executed.
//
// When libc++ has threads, this file is a pure passthrough to the real
// header via #include_next.

#ifndef PSI_WASI_COMPAT_CXX_CONDITION_VARIABLE_H
#define PSI_WASI_COMPAT_CXX_CONDITION_VARIABLE_H

#include <__config>

#if defined(_LIBCPP_HAS_NO_THREADS)
#  define _PSI_WASI_COMPAT_NO_THREADS 1
#elif defined(_LIBCPP_HAS_THREADS) && (_LIBCPP_HAS_THREADS == 0)
#  define _PSI_WASI_COMPAT_NO_THREADS 1
#else
#  define _PSI_WASI_COMPAT_NO_THREADS 0
#endif

#if !_PSI_WASI_COMPAT_NO_THREADS

#include_next <condition_variable>

#else

#include <mutex>
#include <chrono>

_LIBCPP_BEGIN_NAMESPACE_STD

enum class cv_status { no_timeout, timeout };

class condition_variable {
public:
   condition_variable() noexcept                              = default;
   ~condition_variable()                                      = default;
   condition_variable(const condition_variable&)              = delete;
   condition_variable& operator=(const condition_variable&)   = delete;

   void notify_one() noexcept {}
   void notify_all() noexcept {}

   void wait(unique_lock<mutex>&) noexcept {}

   template <class _Predicate>
   void wait(unique_lock<mutex>&, _Predicate __pred) {
      while (!__pred()) {}
   }

   template <class _Rep, class _Period>
   cv_status wait_for(unique_lock<mutex>&,
                      const chrono::duration<_Rep, _Period>&) noexcept {
      return cv_status::no_timeout;
   }

   template <class _Rep, class _Period, class _Predicate>
   bool wait_for(unique_lock<mutex>&,
                 const chrono::duration<_Rep, _Period>&,
                 _Predicate __pred) {
      return __pred();
   }

   template <class _Clock, class _Duration>
   cv_status wait_until(unique_lock<mutex>&,
                        const chrono::time_point<_Clock, _Duration>&) noexcept {
      return cv_status::no_timeout;
   }

   template <class _Clock, class _Duration, class _Predicate>
   bool wait_until(unique_lock<mutex>&,
                   const chrono::time_point<_Clock, _Duration>&,
                   _Predicate __pred) {
      return __pred();
   }
};

_LIBCPP_END_NAMESPACE_STD

#endif // _PSI_WASI_COMPAT_NO_THREADS

#endif // PSI_WASI_COMPAT_CXX_CONDITION_VARIABLE_H
